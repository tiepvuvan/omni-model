{
  "version": 1,
  "server": { "logLevel": "info" },
  "storage": { "type": "memory" },
  "security": {
    "mode": "any",
    "providers": [
      { "type": "firebase-auth", "projectId": "${FIREBASE_PROJECT_ID}" },
      { "type": "firebase-app-check", "projectNumber": "${FIREBASE_PROJECT_NUMBER}" },
      {
        "type": "apple-app-attest",
        "teamId": "${APPLE_TEAM_ID}",
        "bundleId": "${APPLE_BUNDLE_ID}",
        "environment": "development"
      },
      {
        "type": "apple-device-check",
        "teamId": "${APPLE_TEAM_ID}",
        "keyId": "${APPLE_DEVICECHECK_KEY_ID}",
        "privateKey": "${APPLE_DEVICECHECK_KEY}",
        "development": true
      }
    ]
  },
  "rateLimits": [
    { "name": "per-identity-requests", "key": "user", "requests": { "limit": 120, "window": "1m" } }
  ],
  "providers": {
    "openrouter": {
      "type": "openai-compatible",
      "baseUrl": "https://openrouter.ai/api/v1",
      "apiKey": "${OPENROUTER_API_KEY}",
      "headers": {
        "HTTP-Referer": "https://github.com/tiepvuvan/omni-model",
        "X-Title": "omni-model device-auth"
      }
    }
  },
  "routing": { "defaultProvider": "openrouter" }
}
