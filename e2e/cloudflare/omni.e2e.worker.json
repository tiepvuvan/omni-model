{
  "version": 1,
  "server": { "logLevel": "warn" },
  "storage": { "type": "durable-object", "binding": "OMNI_DO" },
  "security": {
    "providers": [
      {
        "type": "jwt",
        "secret": "omni-e2e-shared-secret-not-a-real-credential",
        "algorithms": ["HS256"]
      }
    ]
  },
  "rateLimits": [
    { "name": "per-ip-requests", "key": "ip", "requests": { "limit": 5, "window": "1m" } }
  ],
  "providers": {
    "openrouter": {
      "type": "openai-compatible",
      "baseUrl": "https://openrouter.ai/api/v1",
      "apiKey": "${OPENROUTER_API_KEY}",
      "headers": {
        "HTTP-Referer": "https://github.com/tiepvuvan/omni-model",
        "X-Title": "omni-model e2e (worker)"
      }
    }
  },
  "routing": { "defaultProvider": "openrouter" }
}
