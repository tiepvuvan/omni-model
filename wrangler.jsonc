// Cloudflare Workers deployment for omni-model.
//
//   pnpm --filter omni-model-cloudflare deploy      # `build.command` below compiles first
//
// wrangler is a dependency of apps/cloudflare (not the repo root), so run it
// through that package (or `cd apps/cloudflare` first).
//
// Configuration and provider secrets are environment variables. For example:
//   OMNI_PROVIDERS_DEFAULT_API_KEY=<provider key>
// `.dev.vars.example` lets the Deploy to Cloudflare button prompt for the
// JWT and upstream API-key secrets while the non-secret defaults below are
// deployed automatically.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "omni-model",
  "main": "apps/cloudflare/src/index.ts",
  "compatibility_date": "2025-06-01",
  // The worker imports the workspace packages, which resolve to their built
  // `dist/`. wrangler runs this before bundling, so a FRESH CLONE deploys with
  // nothing but `wrangler deploy` — which is exactly what the one-click
  // "Deploy to Cloudflare" button (Workers Builds) runs. Without it the deploy
  // fails with `Could not resolve "@omni-model/cloudflare"`.
  // Filtered to the two packages the worker needs (`...` pulls in core).
  "build": { "command": "pnpm --filter @omni-model/cloudflare... run build" },
  // A complete, safe one-provider starter. Worker secrets declared in
  // `.dev.vars.example` supply OMNI_SECURITY_JWT_SECRET and the optional
  // OMNI_PROVIDERS_DEFAULT_API_KEY; no application YAML is needed.
  "vars": {
    "OMNI_SERVER_LOG_LEVEL": "info",
    "OMNI_STORAGE_TYPE": "durable-object",
    "OMNI_STORAGE_DURABLE_OBJECT_BINDING": "OMNI_DO",
    "OMNI_SECURITY_JWT_ENABLED": "true",
    "OMNI_SECURITY_JWT_ALGORITHMS": "[\"HS256\"]",
    "OMNI_PROVIDERS_DEFAULT_TYPE": "openai-compatible",
    "OMNI_PROVIDERS_DEFAULT_BASE_URL": "https://api.openai.com/v1",
    "OMNI_RATE_LIMITS_JSON": "[{\"name\":\"per-user-requests\",\"key\":\"user\",\"requests\":{\"limit\":60,\"window\":\"1m\"}},{\"name\":\"per-user-daily-tokens\",\"key\":\"user\",\"tokens\":{\"limit\":200000,\"window\":\"1d\"}}]"
  },
  // Default storage: a Durable Object (exact rate-limit counters). The class
  // is exported by apps/cloudflare/src/index.ts.
  "durable_objects": {
    "bindings": [{ "name": "OMNI_DO", "class_name": "OmniStorageDurableObject" }]
  },
  // SQLite-backed Durable Objects — the kind available on the Workers free plan.
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["OmniStorageDurableObject"] }],
  "observability": { "enabled": true }
  // Alternative: Workers KV storage (approximate counters, eventually
  // consistent). Create the namespace, paste its id below, and switch the
  // config to `storage: { type: cloudflare-kv, binding: OMNI_KV }`:
  //   pnpm --filter omni-model-cloudflare exec wrangler kv namespace create OMNI_KV
  // "kv_namespaces": [{ "binding": "OMNI_KV", "id": "<namespace-id>" }]
}
