# Copy these variables to your deployment environment. This file is an example
# only; omni-model reads configuration from the environment, not from a file.
# Keep actual credentials in your platform's secret store.

OMNI_STORAGE_JSON='{"type":"memory"}'
OMNI_SECURITY_JSON='{"mode":"any","providers":[{"type":"jwt","secret":"${OMNI_JWT_SECRET}","algorithms":["HS256"]}]}'
OMNI_RATE_LIMITS_JSON='[
  {"name":"per-user-requests","key":"user","requests":{"limit":60,"window":"1m"}},
  {"name":"per-user-daily-tokens","key":"user","tokens":{"limit":200000,"window":"1d"}},
  {"name":"free-tier","when":"has(user.claims.tier) && user.claims.tier == \"free\"","key":"user","requests":{"limit":10,"window":"1m"}}
]'
OMNI_PROVIDERS_JSON='{
  "openai":{"type":"openai","apiKey":"${OPENAI_API_KEY}"},
  "anthropic":{"type":"anthropic","apiKey":"${ANTHROPIC_API_KEY}"},
  "google":{"type":"google","apiKey":"${GEMINI_API_KEY}"}
}'
OMNI_ROUTING_JSON='{
  "routes":[
    {"name":"smart-for-pro","when":"request.model == \"smart\" && has(user.claims.tier) && user.claims.tier == \"pro\"","provider":"anthropic","model":"claude-opus-4-8"},
    {"name":"smart-default","when":"request.model == \"smart\"","provider":"openai","model":"gpt-4o-mini"}
  ],
  "modelRules":[
    {"match":"request.model.startsWith(\"claude-\")","provider":"anthropic"},
    {"match":"request.model.startsWith(\"gemini-\")","provider":"google"}
  ],
  "defaultProvider":"openai"
}'
