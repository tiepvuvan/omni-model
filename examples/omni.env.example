# Copy these variables to your deployment environment. This file is an example
# only; omni-model reads configuration from the environment, not from a file.
# Keep actual credentials in your platform's secret store.

# Minimal single-provider setup. The default provider is routed automatically.
OMNI_STORAGE_TYPE=memory
OMNI_SECURITY_MODE=all
OMNI_SECURITY_JWT_ENABLED=true
OMNI_SECURITY_JWT_SECRET='${OMNI_JWT_SECRET}'
OMNI_SECURITY_JWT_ALGORITHMS='["HS256"]'
OMNI_PROVIDERS_DEFAULT_TYPE=openai
OMNI_PROVIDERS_DEFAULT_API_KEY='${OPENAI_API_KEY}'

# Add this JSON array only when you want request/token limits.
OMNI_RATE_LIMITS_JSON='[
  {"name":"per-user-requests","key":"user","requests":{"limit":60,"window":"1m"}},
  {"name":"per-user-daily-tokens","key":"user","tokens":{"limit":200000,"window":"1d"}},
  {"name":"free-tier","when":"has(user.claims.tier) && user.claims.tier == \"free\"","key":"user","requests":{"limit":10,"window":"1m"}}
]'
# For multiple providers or complex model routing, replace the default-provider
# variables with OMNI_PROVIDERS_JSON and OMNI_ROUTING_JSON. The configuration
# reference documents every field and its JSON type.
