{
  "name": "omni-model-proxy-functions",
  "version": "0.1.0",
  "private": true,
  "description": "Cloud Functions source for the omni-model-proxy Firebase Extension.",
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=lib/index.js --external:firebase-admin --external:firebase-functions"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "@omni-model/core": "workspace:*",
    "@omni-model/firebase": "workspace:*",
    "@omni-model/storage-firestore": "workspace:*",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
