{
  "name": "omni-model",
  "description": "Self-hosted OpenAI-compatible AI proxy with environment-configured auth, rate limits and model routing.",
  "repository": "https://github.com/tiepvuvan/omni-model",
  "options": {
    "allow-unauthenticated": true,
    "memory": "512Mi",
    "port": 8787,
    "max-instances": 1
  },
  "env": {
    "OPENAI_API_KEY": {
      "description": "OpenAI API key for the starter OpenAI provider",
      "required": true,
      "order": 10
    },
    "OMNI_JWT_SECRET": {
      "description": "A long random secret for signing client JWTs (HS256)",
      "required": true,
      "order": 20
    },
    "OMNI_SERVER_LOG_LEVEL": {
      "description": "Log level for omni-model",
      "value": "info",
      "required": false,
      "order": 30
    },
    "OMNI_STORAGE_TYPE": {
      "description": "Rate-limit storage type; memory is for the one-instance starter",
      "value": "memory",
      "required": false,
      "order": 40
    },
    "OMNI_SECURITY_JWT_ENABLED": {
      "description": "Enable the starter JWT authentication verifier",
      "value": "true",
      "required": false,
      "order": 50
    },
    "OMNI_SECURITY_JWT_SECRET": {
      "description": "JWT verifier secret reference",
      "value": "${OMNI_JWT_SECRET}",
      "required": false,
      "order": 60
    },
    "OMNI_SECURITY_JWT_ALGORITHMS": {
      "description": "Allowed JWT algorithms (JSON array)",
      "value": "[\"HS256\"]",
      "required": false,
      "order": 70
    },
    "OMNI_PROVIDERS_DEFAULT_TYPE": {
      "description": "Upstream provider type",
      "value": "openai",
      "required": false,
      "order": 80
    },
    "OMNI_PROVIDERS_DEFAULT_API_KEY": {
      "description": "OpenAI provider API key reference",
      "value": "${OPENAI_API_KEY}",
      "required": false,
      "order": 90
    },
    "OMNI_RATE_LIMITS_JSON": {
      "description": "Request and token budget rules (JSON array)",
      "value": "[{\"name\":\"per-user-requests\",\"key\":\"user\",\"requests\":{\"limit\":60,\"window\":\"1m\"}},{\"name\":\"per-user-daily-tokens\",\"key\":\"user\",\"tokens\":{\"limit\":200000,\"window\":\"1d\"}}]",
      "required": false,
      "order": 100
    }
  }
}
